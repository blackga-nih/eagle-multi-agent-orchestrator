{
  "version": "2026-04-22",
  "rfo_notes": "FAC 2025-06 / HHS Class Deviation 2026-01 eff. Nov 21 2025: MPT raised $10K→$15K, SAT raised $250K→$350K, VETS 4212 threshold $150K added. Use this file as authoritative source; do not rely on memorized values.",

  "intake_required_facts": {
    "_note": "Required facts the supervisor must collect BEFORE calling create_document for each doc_type. Used by both supervisor prompt (fast-path) and the backend validator in exec_create_document (correctness guarantee). See handoff 20260422-handoff-intake-gate-budget-semantics-v1.md for rationale.",
    "pws":              { "required": ["scope", "pop", "place_of_performance", "event_cadence", "deliverable_format"], "blocker": true },
    "sow":              { "required": ["scope", "pop", "place_of_performance", "task_breakdown"], "blocker": true },
    "igce":             { "required": ["scope", "pop", "labor_categories_or_line_items", "budget_ceiling"], "blocker": true },
    "market_research":  { "required": ["scope", "naics_or_category", "estimated_value_range"], "blocker": true },
    "acquisition_plan": { "required": ["scope", "igce_value", "contract_type", "competition_approach"], "blocker": true },
    "ja":               { "required": ["scope", "proposed_contractor", "authority_far_6_302_x", "sole_source_rationale"], "blocker": true },
    "justification":    { "required": ["scope", "proposed_contractor", "authority_far_6_302_x", "sole_source_rationale"], "blocker": true }
  },

  "budget_semantics": {
    "_note": "Rules governing how budget and IGCE interact. The supervisor and every subagent with create_document access MUST respect these. Prompt-enforced (no backend validator — the validator for intake_required_facts already forces matrix-read discipline). See handoff 20260422 for rationale.",
    "budget_is_ceiling": true,
    "igce_is_estimated_value": true,
    "propagation": "IGCE auto-propagates as estimated_value to AP, J&A, SSP, and downstream docs",
    "locked_after_intake": ["budget_ceiling"],
    "forbidden_behaviors": [
      "asking user to reconcile IGCE vs budget",
      "suggesting scope expansion to consume remaining budget",
      "inflating quantities/rates to reach a budget target",
      "recommending a contract value that exceeds budget_ceiling"
    ]
  },

  "thresholds": [
    { "value": 15000,     "label": "$15K MPT",      "short": "$15K",   "triggers": ["micro_purchase_threshold", "competition_not_required"] },
    { "value": 25000,     "label": "$25K Synopsis",  "short": "$25K",   "triggers": ["sam_gov_synopsis_required"] },
    { "value": 150000,    "label": "$150K VETS 4212","short": "$150K",  "triggers": ["vets_4212_affirmative_action_plan"] },
    { "value": 350000,    "label": "$350K SAT",      "short": "$350K",  "triggers": ["simplified_acquisition_threshold", "full_competition_required_above"] },
    { "value": 750000,    "label": "$750K SubK",     "short": "$750K",  "triggers": ["subcontracting_plan_required"] },
    { "value": 900000,    "label": "$900K J&A",      "short": "$900K",  "triggers": ["ja_hca_approval_required"] },
    { "value": 2000000,   "label": "$2M TINA",       "short": "$2M",    "triggers": ["certified_cost_pricing_data_required"] },
    { "value": 4500000,   "label": "$4.5M 8a SS",    "short": "$4.5M",  "triggers": ["8a_sole_source_services_ceiling"] },
    { "value": 7000000,   "label": "$7M 8a Mfg",     "short": "$7M",    "triggers": ["8a_sole_source_manufacturing_ceiling"] },
    { "value": 7500000,   "label": "$7.5M IDIQ Enh", "short": "$7.5M",  "triggers": ["idiq_enhanced_competition"] },
    { "value": 20000000,  "label": "$20M AP",        "short": "$20M",   "triggers": ["written_acquisition_plan_required"] },
    { "value": 50000000,  "label": "$50M HCA",       "short": "$50M",   "triggers": ["hca_approval_required"] },
    { "value": 90000000,  "label": "$90M SPE J&A",   "short": "$90M",   "triggers": ["spe_ja_approval_required"] },
    { "value": 150000000, "label": "$150M OAP",      "short": "$150M",  "triggers": ["oap_approval_required"] }
  ],

  "contract_types": [
    { "id": "ffp",    "label": "Firm-Fixed-Price (FFP)",        "risk": 95, "category": "fp",     "prereqs": [] },
    { "id": "fp-epa", "label": "FP w/ Economic Price Adj",      "risk": 80, "category": "fp",     "prereqs": [] },
    { "id": "fpi",    "label": "Fixed-Price Incentive (FPIF)",   "risk": 65, "category": "fp",     "prereqs": [] },
    { "id": "fp-af",  "label": "FP w/ Award Fee (FP/AF)",        "risk": 60, "category": "fp",     "fee_cap": "Award fee variable", "prereqs": [] },
    { "id": "cpff",   "label": "Cost-Plus-Fixed-Fee (CPFF)",     "risk": 25, "category": "cr",     "fee_cap": "10% est. cost (R&D: 15%)", "prereqs": ["Adequate cost accounting system"] },
    { "id": "cpif",   "label": "Cost-Plus-Incentive-Fee (CPIF)", "risk": 35, "category": "cr",     "fee_cap": "Sharing ratio applies", "prereqs": ["Adequate cost accounting system"] },
    { "id": "cpaf",   "label": "Cost-Plus-Award-Fee (CPAF)",     "risk": 20, "category": "cr",     "fee_cap": "No rollover allowed", "prereqs": ["Adequate cost accounting system", "Award fee plan"] },
    { "id": "tm",     "label": "Time & Materials (T&M)",         "risk": 15, "category": "loe",    "prereqs": ["D&F required", "Ceiling price established"] },
    { "id": "lh",     "label": "Labor-Hour (LH)",                "risk": 15, "category": "loe",    "prereqs": ["D&F required"] },
    { "id": "letter", "label": "Letter Contract (Emergency)",    "risk": 5,  "category": "letter", "fee_cap": "Definitize ≤180 days/40%", "prereqs": ["HCA determination required", "Definitization schedule"] }
  ],

  "doc_rules": {
    "always": [
      "Purchase Request"
    ],
    "above_threshold": [
      {
        "above": 0,
        "docs": ["Purchase Request"]
      },
      {
        "above": 15000,
        "label": "Simplified Acquisition ($15K–$350K)",
        "far": "Part 13",
        "docs": ["Statement of Work (SOW)", "Independent Government Cost Estimate (IGCE)", "Market Research Report"]
      },
      {
        "above": 25000,
        "label": "SAM.gov synopsis required",
        "docs": ["SAM.gov Synopsis"]
      },
      {
        "above": 150000,
        "label": "VETS 4212 affirmative action",
        "docs": ["VETS 4212 Compliance Certification"]
      },
      {
        "above": 350000,
        "label": "Negotiated Acquisition (>$350K)",
        "far": "Part 15",
        "docs": ["Technical Evaluation Plan", "Past Performance Evaluation Plan", "Price/Cost Analysis", "D&F (if applicable)", "Sources Sought Notice"]
      },
      {
        "above": 750000,
        "label": "Subcontracting plan required",
        "docs": ["Subcontracting Plan"]
      },
      {
        "above": 2000000,
        "label": "TINA — certified cost data",
        "docs": ["Certified Cost or Pricing Data (SF 1411 or equivalent)"]
      },
      {
        "above": 20000000,
        "label": "Written Acquisition Plan required",
        "far": "FAR 7.105",
        "docs": ["Written Acquisition Plan"]
      }
    ],
    "by_method": {
      "sole": [
        "Justification & Approval (J&A)",
        "Market Research Report (documenting why sole source)",
        "Statement of Need"
      ],
      "negotiated": [
        "Solicitation (RFP/RFQ)",
        "Technical Evaluation Plan",
        "Source Selection Plan",
        "Price/Cost Analysis"
      ],
      "idiq": [
        "IDIQ Ordering Agreement",
        "Task/Delivery Order",
        "Competition documentation for orders >$3K"
      ]
    },
    "by_type": {
      "tm": [
        "Determination & Findings (D&F) for T&M — one level above CO",
        "Labor rate documentation",
        "Ceiling price with adequate controls"
      ],
      "letter": [
        "HCA Determination for Letter Contract",
        "Definitization schedule (≤180 days or 40% of estimated cost)",
        "Limitation of government obligation clause"
      ],
      "cpaf": [
        "Award Fee Plan",
        "Award Fee Board composition",
        "Performance evaluation periods and criteria"
      ]
    },
    "special_factors": {
      "isIT": [
        "Section 508 Compliance Documentation",
        "IT Security Assessment (FISMA)",
        "Authority to Operate (ATO) or waiver"
      ],
      "isSB": [
        "Small Business Set-Aside Determination",
        "SBA Size Standard Verification",
        "Set-aside rationale (Rule of Two analysis)"
      ],
      "isRD": [
        "Statement of Work with research objectives",
        "Data rights and IP clauses (FAR 27.4)",
        "Human subjects / animal welfare compliance (if applicable)"
      ],
      "isHS": [
        "HIPAA Business Associate Agreement (if applicable)",
        "Health data handling protocol",
        "Security clearance requirements (if any)"
      ],
      "isAnimalWelfare": [
        "IACUC Approval / Protocol Number",
        "Animal Welfare Act compliance certification",
        "USDA reporting requirements"
      ],
      "isForeign": [
        "Foreign Acquisition certification (FAR 25)",
        "Trade Agreements Act compliance",
        "Buy American Act waiver (if required)"
      ],
      "isConference": [
        "Conference Approval (HHS prior approval ≥$100K)",
        "Conference Report",
        "Food/alcohol restrictions documentation"
      ],
      "isServices": [
        "Service Contract Act wage determination",
        "Inherently Governmental / closely associated function analysis",
        "Personal services prohibition determination"
      ]
    }
  },

  "approval_chains": {
    "_source": "HCA_SPE_Approval_Thresholds_Updated.txt (April 2026, HHSAM Note 2026-03 + FAC 2025-06).",
    "_designee_note": "Per FAR 1.602-1 / HHSAR 1.604, named authorities (HCA, SPE, OA Director) may delegate downstream UNLESS explicitly marked non-delegable. Always include 'or designee' and add the Competition Advocate, OSDBU, and AOD touch-points where the regulation requires them — naming only one role is a Q4 review failure mode.",
    "ja": [
      { "ceiling": 900000,    "authority": "Contracting Officer (CO) or other approval established by OA",  "note": "FAR 6.304(a)(1). At/below $900K J&A ceiling per FAC 2025-06." },
      { "ceiling": 20000000,  "authority": "HCA + NIH Competition Advocate",                                "note": "FAR 6.304(a)(2)/(a)(3). $900,001–$20M tier requires BOTH HCA and Competition Advocate review. Either alone is insufficient." },
      { "ceiling": 90000000,  "authority": "HCA + NIH Competition Advocate + additional reviews",           "note": "FAR 6.304(a)(3). $20M–$90M tier requires HCA AND Competition Advocate AND additional designated reviews — HCA alone (or any single role) is NOT sufficient. Q4 review (2026-04-29) flagged that EAGLE was naming only HPA/HCA at this tier; correct chain is multi-role." },
      { "ceiling": null,      "authority": "SPE through HHS/OAP and HHS Competition Advocate",              "note": "FAR 6.304(a)(4). Above $90M — SPE signs through HHS/OAP." }
    ],
    "fss_ssj": [
      { "ceiling": 350000,    "authority": "CO documents in requisition / contract file",                   "note": "At/below SAT — no formal SSJ required (GSAM/R 538.7104-3, justification in requisition paragraph)." },
      { "ceiling": 900000,    "authority": "CO certification serves as approval",                           "note": "HHSAM 308.401(b)(2) — >SAT to $900K." },
      { "ceiling": 20000000,  "authority": "Division-level Advocate for Competition (NOT delegable)",       "note": "HHSAM 308.401(b)(2) — $900K to $20M. Non-delegable per HHSAM." },
      { "ceiling": 90000000,  "authority": "HCA approval required",                                          "note": "HHSAM 308.401(b)(2) — >$20M FSS SSJ." },
      { "ceiling": null,      "authority": "HCA approval + AOD submission within 5 business days",          "note": "HHSAM 308.401(b)(2) — >$90M FSS SSJ. Email Acquisition_Oversight@hhs.gov." }
    ],
    "ap": [
      { "ceiling": 20000000,  "authority": "One level above Contracting Officer",                            "note": "HHS internal — SAT to $20M tier reviewed one level above CO." },
      { "ceiling": 50000000,  "authority": "OA Director or designee approved by HCA",                        "note": "HHS internal — $20M–$50M tier. OA Director may designate; HCA must approve." },
      { "ceiling": 150000000, "authority": "HCA-NIH",                                                         "note": "HHS internal — $50M–$150M tier." },
      { "ceiling": null,      "authority": "HHS/OAP + OSDBU pre-submission approval",                        "note": "Above $150M — HHSAM 310.001-72(f) (April 2026) requires OSDBU approval BEFORE OAP submission." }
    ],
    "as": [
      { "ceiling": 50000000,   "authority": "OA Director or designee approved by HCA",                       "note": "Acquisition Strategy — under $50M lifecycle." },
      { "ceiling": 100000000,  "authority": "HCA-NIH",                                                        "note": "$50M–$100M lifecycle." },
      { "ceiling": 150000000,  "authority": "Deputy Director for Management, NIH",                            "note": "$100M–$150M lifecycle." },
      { "ceiling": null,       "authority": "HHS/Office of Acquisition Policy (OAP)",                         "note": ">=$150M lifecycle." }
    ]
  },

  "warnings": {
    "letter":       "Letter contracts must be definitized within 180 days or 40% of estimated contract cost, whichever comes first. Failure to definitize triggers FAR 16.603-2 remedies.",
    "idiq_protest": "IDIQ task orders over $10M are protestable at GAO under the Fair Acquisition through Interagency Contracting Act. Ensure competitive procedures among awardees.",
    "tm":           "T&M contracts provide no positive incentive for cost control. Use only when no other type is suitable and the CO executes a D&F approved one level above. Establish a firm ceiling price."
  },

  "hhs_nih_docs": {
    "_note": "HHS/NIH-specific document requirements from File Reviewer's Checklist (FRC) and HHS PMR Common Requirements. Supplements the FAR-based doc_rules above.",
    "always": [
      { "name": "Required & Priority Sources Checklist", "ref": "FRC A2 / FAR 8.002", "note": "Mandatory sources checked in priority order" },
      { "name": "Section 889 Compliance Documentation", "ref": "FAR 52.204-24/25", "note": "Covered telecom equipment prohibition" },
      { "name": "SAM Registration & Exclusions Check", "ref": "FRC D1 / FAR 9.405(e)", "note": "Check at receipt AND prior to award; document both" }
    ],
    "above_threshold": [
      {
        "above": 0,
        "docs": [
          { "name": "Price Reasonableness Determination", "ref": "FRC C1", "note": "Documented basis (market research, historical pricing)" }
