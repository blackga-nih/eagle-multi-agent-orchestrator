# Multi-stage build for Next.js standalone output
# Optimized for ECS Fargate deployment

# ── Stage 1: Dependencies ─────────────────────────────────────
FROM node:20-alpine AS deps
WORKDIR /app

COPY client/package.json client/package-lock.json ./
RUN npm ci --production=false

# ── Stage 2: Build ────────────────────────────────────────────
FROM node:20-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY client/ ./

# Build-time env vars. Next.js standalone output bakes rewrites() into
# routes-manifest.json at build, so FASTAPI_URL MUST be set as a build
# arg — runtime task-def env vars are not consulted by the standalone
# server when serving the baked rewrites. Without this the /api/auth/*
# and /ws/* rewrites fall back to http://localhost:8000 and proxy
# requests get ECONNREFUSED at runtime (root cause of the Entra
# callback failure observed 2026-05-14).
ARG FASTAPI_URL=http://localhost:8000
ENV FASTAPI_URL=$FASTAPI_URL

RUN npm run build

# ── Stage 3: Production ──────────────────────────────────────
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

# Install curl for ECS health checks
RUN apk add --no-cache curl

# Create non-root user
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

# Copy standalone output
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs

EXPOSE 3000

CMD ["node", "server.js"]
