# Environment Configuration for EAGLE NCI Acquisition Assistant

# AWS Cognito Configuration (Required)
COGNITO_USER_POOL_ID=your-cognito-user-pool-id
COGNITO_CLIENT_ID=your-cognito-client-id

# DynamoDB Configuration (Required)
EAGLE_SESSIONS_TABLE=eagle

# AWS Bedrock Configuration (Legacy - optional)
BEDROCK_AGENT_ID=your-bedrock-agent-id
AWS_REGION=us-east-1

# Anthropic SDK Configuration (EAGLE)
# Option 1: Direct Anthropic API
ANTHROPIC_API_KEY=your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Option 2: Amazon Bedrock (uses AWS credentials, no API key needed)
USE_BEDROCK=false
# EAGLE_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# S3 Document Storage
S3_BUCKET=eagle-documents-695681773636-dev
S3_PREFIX=eagle/

# Security Configuration
JWT_SECRET=your-jwt-secret-key

# Real-time Weather API Configuration (Optional - MCP Weather Tools)
OPENWEATHER_API_KEY=your-openweathermap-api-key

# EAGLE Feature Flags
USE_PERSISTENT_SESSIONS=true
REQUIRE_AUTH=false
DEV_MODE=false
DEV_USER_ID=dev-user
DEV_TENANT_ID=dev-tenant

# Application Configuration
DEBUG=true
APP_PORT=8000

# OpenClaw Gateway (Optional)
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# Cost Configuration
COST_INPUT_PER_1K=0.003
COST_OUTPUT_PER_1K=0.015

# Session Configuration
SESSION_TTL_DAYS=30

# JIRA Feedback Pipeline
JIRA_BASE_URL=https://tracker.nci.nih.gov
JIRA_API_TOKEN=your-personal-access-token
JIRA_PROJECT=EAGLE
JIRA_TIMEOUT=5.0
JIRA_FEEDBACK_ENABLED=false

# Power Automate Feedback Action URLs (buttons hidden if not set)
PA_FEEDBACK_APPROVE_URL=
PA_FEEDBACK_REJECT_URL=
PA_FEEDBACK_RESEND_URL=
