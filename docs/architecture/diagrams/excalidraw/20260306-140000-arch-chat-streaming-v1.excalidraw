    {
      "type": "text",
      "id": "sse_evidence_body",
      "x": 30,
      "y": 500,
      "width": 800,
      "height": 92,
      "text": "data: {\"type\":\"text\",    \"agent_id\":\"eagle\", \"content\":\"Here is your SOW...\",        \"timestamp\":\"...\"}\ndata: {\"type\":\"tool_use\", \"agent_id\":\"eagle\", \"tool_use\":{\"name\":\"create_document\",\"input\":{...}}}\ndata: {\"type\":\"tool_result\",\"agent_id\":\"eagle\",\"tool_result\":{\"name\":\"create_document\",\"result\":{...}}}\ndata: {\"type\":\"complete\",  \"agent_id\":\"eagle\",  \"timestamp\":\"...\"}\ndata: {\"type\":\"error\",     \"agent_id\":\"eagle\",  \"content\":\"Rate limit exceeded\"}\n: keepalive                                          (every 20s, ALB idle timeout = 300s)",
      "originalText": "data: {\"type\":\"text\",    \"agent_id\":\"eagle\", \"content\":\"Here is your SOW...\",        \"timestamp\":\"...\"}\ndata: {\"type\":\"tool_use\", \"agent_id\":\"eagle\", \"tool_use\":{\"name\":\"create_document\",\"input\":{...}}}\ndata: {\"type\":\"tool_result\",\"agent_id\":\"eagle\",\"tool_result\":{\"name\":\"create_document\",\"result\":{...}}}\ndata: {\"type\":\"complete\",  \"agent_id\":\"eagle\",  \"timestamp\":\"...\"}\ndata: {\"type\":\"error\",     \"agent_id\":\"eagle\",  \"content\":\"Rate limit exceeded\"}\n: keepalive                                          (every 20s, ALB idle timeout = 300s)",
